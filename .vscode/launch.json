{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Correr con input.txt",
            "program": "${workspaceFolder}/index.js",
            "args": ["input.txt"],
            "runtimeArgs": ["--experimental-vm-modules"],
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Correr con valido1.txt",
            "program": "${workspaceFolder}/index.js",
